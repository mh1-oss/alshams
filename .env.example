# Optional: use a hosted endpoint instead of the local /api/contact route.
VITE_CONTACT_ENDPOINT=/api/contact

# Server-only variables. Never prefix these with VITE_ or expose them to the browser.
# Copy this file to .env and fill in real values (see @BotFather for the token,
# and your own Telegram user id for the chat id — open a chat with the bot first).
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here
